{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": ["src/routes/analysis.js", "src/services/llm.js", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
