# =============================================================================
# ICS Defense Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# 配置分两层:
#   1. 环境变量 (.env): 仅存放启动引导配置 (DB_PATH, PORT, REDIS_URL)
#   2. system_config 表: 所有运行时配置 (LLM, auth, guard, 通知等)
#      可通过 /api/config 接口或前端设置页修改
# =============================================================================

# --- Database ---
DB_PATH=./data/ics_defense.db

# --- Server ---
PORT=8002

# --- Redis (optional — platform works without it) ---
REDIS_URL=redis://localhost:6379

# --- MCP Server Config ---
MCP_CONFIG_PATH=agent/mcp_servers.yaml

# --- Docker Compose port overrides ---
REDIS_PORT=6379
FRONTEND_PORT=80
