# =============================================================================
# ICS Defense Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# These variables override the corresponding values in config.yaml.
# =============================================================================

# --- LLM Provider (XAI / Grok) ---
XAI_API_KEY=your-xai-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini-fast

# --- Database ---
DB_PATH=./data/ics_defense.db

# --- Redis (optional — platform works without it) ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=8002

# --- Auth ---
API_TOKEN=

# --- Notification Provider ("noop" | "feishu" | "webhook") ---
NOTIFICATION_PROVIDER=noop

# --- Feishu / Lark Integration (optional) ---
FEISHU_BOT_WEBHOOK_URL=
FEISHU_BOT_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_RECEIVE_ID=
FEISHU_APP_RECEIVE_ID_TYPE=chat_id

# --- Docker Compose port overrides ---
REDIS_PORT=6379
FRONTEND_PORT=80
