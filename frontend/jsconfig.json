{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": "."
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
